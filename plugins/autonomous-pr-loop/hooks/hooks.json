{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/dist/pre-tool-use.js\"",
            "timeout": 1000,
            "statusMessage": "Checking agent-loop command policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/dist/post-tool-use.js\"",
            "timeout": 500,
            "statusMessage": "Recording agent-loop PostToolUse event"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/dist/user-prompt-submit.js\"",
